{
  "name": "esperantai",
  "version": "2.0.0",
  "private": true,
  "description": "Los gestos honestos — AI gesture controller for streamers (OBS, Streamlabs, vMix, PRISM, XSplit)",
  "license": "SEE LICENSE IN LICENSE.txt",
  "homepage": "https://edugame.digital/",
  "repository": {
    "type": "git",
    "url": "https://github.com/salazarjoelo/EsperantAI.git"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint core/ adapters/ platforms/ app.js",
    "validate-json": "node scripts/validate-json.mjs",
    "validate-csp": "node scripts/validate-csp.mjs",
    "validate-locales": "node scripts/validate-locales-parity.mjs",
    "validate": "npm run validate-json && npm run validate-csp && npm run validate-locales",
    "benchmark": "node scripts/benchmark-detector.mjs"
  },
  "devDependencies": {
    "@napi-rs/canvas": "^1.0.0",
    "@tensorflow/tfjs-backend-cpu": "^4.22.0",
    "@tensorflow/tfjs-backend-wasm": "^4.22.0",
    "@tensorflow/tfjs-converter": "^4.22.0",
    "@tensorflow/tfjs-core": "^4.22.0",
    "@vitest/coverage-v8": "^3.1.1",
    "@vladmandic/human": "^3.3.6",
    "eslint": "^9.18.0",
    "eslint-plugin-no-unsanitized": "^4.1.2",
    "eslint-plugin-security": "^3.0.1",
    "globals": "^15.14.0",
    "jsdom": "^26.0.0",
    "vitest": "^3.1.1"
  }
}
