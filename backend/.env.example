# EsperantAI License Backend — environment variables
# Copia este archivo a `.env` y rellena los valores reales.
# NUNCA commitear .env al repo (está en .gitignore).

# ─────────────────────────────────────────────────────────────────
# LemonSqueezy
# ─────────────────────────────────────────────────────────────────
# Dashboard → Settings → API → Create new API key. Scopes recomendados:
#   - licenses:read
#   - licenses:write (para deactivate)
# Mantener este key SECRETO. Si se filtra, regenerarlo inmediatamente.
LEMONSQUEEZY_API_KEY=lmsq_apikey_replace_me

# Webhook signing secret. LemonSqueezy Dashboard → Settings → Webhooks → tu webhook
# → Signing Secret. Diferente del API key.
LEMONSQUEEZY_WEBHOOK_SECRET=whsec_replace_me

# Variant IDs de los productos en LemonSqueezy. Son obligatorios:
# el backend rechaza cualquier licencia válida cuyo variant_id no esté aquí
# para evitar que una key de otro producto/tienda active EsperantAI.
# Dashboard → Products → tu producto → Variants → copiar Variant ID (numérico).
LEMONSQUEEZY_VARIANT_PRO=replace_me_variant_id_pro
LEMONSQUEEZY_VARIANT_PRO_PLUS=replace_me_variant_id_pro_plus

# ─────────────────────────────────────────────────────────────────
# JWT signing (Ed25519)
# ─────────────────────────────────────────────────────────────────
# Path absoluto a priv.pem generado con scripts/generate-keypair.js
# Default: /etc/esperantai/priv.pem (recomendado, chmod 600, owner del service)
PRIV_KEY_PATH=/etc/esperantai/priv.pem

# Path al public key (mismo dir). El cliente trae una copia hardcoded en
# core/license-manager.js, esto es solo para que el backend pueda firmar+verificar.
PUB_KEY_PATH=/etc/esperantai/pub.pem

# Días que dura el JWT antes de expirar. El cliente reverifica antes de expirar.
JWT_TTL_DAYS=30

# ─────────────────────────────────────────────────────────────────
# Revocations & JTI replay protection (Z-SEC-04, Z-SEC-05)
# ─────────────────────────────────────────────────────────────────
# SQLite con tokens revocados. Default: /var/lib/esperantai/revocations.db
# Owner del file debe match el User= del systemd service (edugame).
DB_PATH=/var/lib/esperantai/revocations.db

# JSON con JTIs activos para anti-replay. Default: /var/lib/esperantai/active-jtis.json
JTI_STORE_PATH=/var/lib/esperantai/active-jtis.json

# ─────────────────────────────────────────────────────────────────
# Admin endpoint
# ─────────────────────────────────────────────────────────────────
# Token bearer para endpoints administrativos (revoke individual licenses,
# inspect state, etc.). Genera 64 chars random:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_TOKEN=replace_me_64_char_hex_token

# ─────────────────────────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────────────────────────
# Origins separados por coma. Default: solo el origen oficial del producto.
# Para dev local: añadir http://127.0.0.1:8765 (el python -m http.server).
# Para prod: solo el dominio donde corre la app (edugame.digital, esperantai.com, etc).
ALLOWED_ORIGINS=https://edugame.digital,https://esperantai.com

# ─────────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────────
PORT=3201
HOST=127.0.0.1
